---
import type { Lang } from '../i18n';
import { t, localePath, otherLang } from '../i18n';

interface Props {
  lang: Lang;
  pathname: string;
}

const { lang, pathname } = Astro.props;
const s = t(lang);

// Phase 1 nav: Home, About, Products, Contact only.
// Careers / Blog / Compliance are reserved for Phase 2+ but the strings remain in i18n.
const links = [
  { href: localePath(lang, '/'), label: s.nav.home },
  { href: localePath(lang, '/about'), label: s.nav.about },
  { href: localePath(lang, '/products'), label: s.nav.products },
  { href: localePath(lang, '/contact'), label: s.nav.contact },
];

const stripPrefix = (p: string) => {
  if (p.startsWith('/en/')) return p.slice(3);
  if (p === '/en') return '/';
  return p;
};
const altLang = otherLang(lang);
const altPath = localePath(altLang, stripPrefix(pathname));
---
<header class="border-b border-navy/10 bg-white/80 backdrop-blur sticky top-0 z-30">
  <div class="container-page flex items-center justify-between h-16">
    <a href={localePath(lang, '/')} class="flex items-center gap-3">
      <img src="/logo.svg" alt={s.meta.siteName} class="h-8 w-auto" width="32" height="32" />
      <span class="font-bold text-navy">{s.meta.siteName}</span>
    </a>
    <nav class="hidden md:flex items-center gap-6 text-sm" aria-label={s.nav.home}>
      {links.map((l) => (
        <a href={l.href} class="text-charcoal/80 hover:text-navy transition">{l.label}</a>
      ))}
    </nav>
    <a
      href={altPath}
      class="text-sm font-bold text-navy border border-navy/20 rounded px-3 py-1.5 hover:bg-navy/5"
      hreflang={altLang}
      lang={altLang}
      dir={altLang === 'ar' ? 'rtl' : 'ltr'}
    >
      {s.langToggle}
    </a>
  </div>
</header>
