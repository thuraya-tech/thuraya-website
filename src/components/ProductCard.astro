---
interface Props {
  title: string;
  description: string;
  href: string;
  cta: string;
  external?: boolean;
}
const { title, description, href, cta, external = false } = Astro.props;
---
<article class="card group">
  <div class="text-sm font-bold text-gold tracking-wide uppercase">{title}</div>
  <p class="mt-3 text-charcoal/90">{description}</p>
  <a
    href={href}
    rel={external ? 'noopener' : undefined}
    class="inline-block mt-5 font-bold text-navy hover:text-gold transition"
  >
    {cta} <span aria-hidden="true">→</span>
  </a>
</article>
