---
import type { Lang } from '../i18n';
import { t } from '../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const f = t(lang).contact.form;
---
<!--
  TODO wire-up: this form posts to /api/contact.
  Stub until Faris/Nour wire up an Astro server endpoint or external form
  service (e.g. Cloudflare Pages Function -> Resend/SES, or Formspree).
  Currently submits prevent-default and shows a confirmation alert.
-->
<form
  class="card max-w-2xl space-y-5"
  action="/api/contact"
  method="POST"
  onsubmit="event.preventDefault(); alert(this.dataset.stubMsg);"
  data-stub-msg={f.note}
>
  <div>
    <label for="name" class="block text-sm font-bold text-charcoal mb-1">{f.name}</label>
    <input id="name" name="name" type="text" required class="w-full rounded-md border border-navy/20 bg-white px-3 py-2 focus:border-gold focus:outline-none" />
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <label for="email" class="block text-sm font-bold text-charcoal mb-1">{f.email}</label>
      <input id="email" name="email" type="email" required class="w-full rounded-md border border-navy/20 bg-white px-3 py-2 focus:border-gold focus:outline-none" />
    </div>
    <div>
      <label for="company" class="block text-sm font-bold text-charcoal mb-1">{f.company}</label>
      <input id="company" name="company" type="text" class="w-full rounded-md border border-navy/20 bg-white px-3 py-2 focus:border-gold focus:outline-none" />
    </div>
  </div>
  <div class="grid md:grid-cols-2 gap-5">
    <div>
      <label for="role" class="block text-sm font-bold text-charcoal mb-1">{f.role}</label>
      <input id="role" name="role" type="text" class="w-full rounded-md border border-navy/20 bg-white px-3 py-2 focus:border-gold focus:outline-none" />
    </div>
    <div>
      <label for="product" class="block text-sm font-bold text-charcoal mb-1">{f.product}</label>
      <select id="product" name="product" class="w-full rounded-md border border-navy/20 bg-white px-3 py-2 focus:border-gold focus:outline-none">
        {f.productOptions.map((opt) => <option value={opt}>{opt}</option>)}
      </select>
    </div>
  </div>
  <div>
    <label for="message" class="block text-sm font-bold text-charcoal mb-1">{f.message}</label>
    <textarea id="message" name="message" rows="5" required class="w-full rounded-md border border-navy/20 bg-white px-3 py-2 focus:border-gold focus:outline-none"></textarea>
  </div>
  <button type="submit" class="btn-primary">{f.submit}</button>
  <p class="text-xs text-muted">{f.note}</p>
</form>
