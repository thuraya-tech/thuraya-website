---
import type { Lang } from '../../i18n';
import { t } from '../../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const p = t(lang).privacy;
---
<!-- TODO copy review: Ali + legal counsel to confirm PDPL boilerplate
     before publishing publicly. DPO contact (dpo@thuraya.tech) is a placeholder. -->
<section class="container-page py-20">
  <h1 class="h-display text-navy">{p.title}</h1>
  <p class="lead mt-5 max-w-3xl">{p.intro}</p>
  <p class="mt-3 text-sm text-muted">{p.lastUpdated}</p>
</section>

<section class="container-page pb-24">
  <div class="card max-w-3xl space-y-8">
    {p.sections.map((sec) => (
      <div>
        <h2 class="text-xl font-bold text-navy">{sec.heading}</h2>
        <p class="mt-2 text-charcoal/85 leading-relaxed">{sec.body}</p>
      </div>
    ))}
  </div>
</section>
