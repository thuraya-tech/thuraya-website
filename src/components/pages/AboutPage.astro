---
import type { Lang } from '../../i18n';
import { t } from '../../i18n';

interface Props { lang: Lang }
const { lang } = Astro.props;
const a = t(lang).about;
---
<section class="container-page py-20">
  <h1 class="h-display text-navy">{a.title}</h1>
  <p class="lead mt-5 max-w-3xl">{a.lead}</p>
</section>

<section class="container-page pb-12">
  <div class="card max-w-3xl">
    <h2 class="text-2xl font-bold text-navy">{a.storyTitle}</h2>
    <p class="mt-3 text-charcoal/85 leading-relaxed">{a.storyBody}</p>
  </div>
</section>

<section class="container-page py-6 grid md:grid-cols-2 gap-6">
  <div class="card">
    <h2 class="text-2xl font-bold text-navy">{a.missionTitle}</h2>
    <p class="mt-3 text-charcoal/85">{a.missionBody}</p>
  </div>
  <div class="card">
    <h2 class="text-2xl font-bold text-navy">{a.visionTitle}</h2>
    <p class="mt-3 text-charcoal/85">{a.visionBody}</p>
  </div>
</section>

<section class="container-page py-20">
  <h2 class="h-section text-navy">{a.valuesTitle}</h2>
  <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mt-8">
    {a.values.map((v) => (
      <article class="card">
        <h3 class="text-lg font-bold text-navy">{v.title}</h3>
        <p class="mt-2 text-sm text-charcoal/80">{v.body}</p>
      </article>
    ))}
  </div>
</section>
