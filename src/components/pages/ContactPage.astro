---
import type { Lang } from '../../i18n';
import { t } from '../../i18n';
import ContactForm from '../ContactForm.astro';

interface Props { lang: Lang }
const { lang } = Astro.props;
const c = t(lang).contact;
---
<section class="container-page py-20">
  <h1 class="h-display text-navy">{c.title}</h1>
  <p class="lead mt-5 max-w-3xl">{c.lead}</p>
</section>

<section class="container-page pb-24 grid md:grid-cols-3 gap-8">
  <div class="md:col-span-2">
    <ContactForm lang={lang} />
  </div>
  <aside class="space-y-5">
    <div class="card">
      <h2 class="text-lg font-bold text-navy">{c.addressTitle}</h2>
      <p class="mt-2 text-charcoal/85">{c.addressBody}</p>
    </div>
    <div class="card">
      <h2 class="text-lg font-bold text-navy">{c.emailLabel}</h2>
      <p class="mt-2">
        <a href="mailto:hello@thuraya.tech" class="text-navy font-medium hover:text-gold">hello@thuraya.tech</a>
      </p>
    </div>
    <div class="card bg-navy text-white border-navy">
      <p class="text-sm text-white/85">{c.sla}</p>
    </div>
  </aside>
</section>
